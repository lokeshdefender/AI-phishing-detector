# ── Required ──────────────────────────────────────────
# Get your free API key from: https://groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ──────────────────────────────────────────
# Get your free API key from: https://www.virustotal.com
# Used for URL reputation scanning (4 requests/min on free tier)
# App works without this but URL scanning will be disabled
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── Runtime ───────────────────────────────────────────
# Set to "development" to enable auto-reload (local dev only)
# Leave unset or set to "production" for deployment
ENV=development

# ── App Runtime (Production Readiness) ───────────────
APP_ENV=development
APP_VERSION=0.3.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
LOG_LEVEL=INFO

# Comma-separated list (or * for development)
CORS_ALLOW_ORIGINS=*

# Cookie/session hardening
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Auth/JWT settings
AUTH_SECRET_KEY=change-me-in-production
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=240

# Database and storage
DATABASE_URL=sqlite:///./investigations.db
EVIDENCE_STORAGE_PATH=./evidence_repository
EVIDENCE_MAX_FILE_SIZE_BYTES=26214400